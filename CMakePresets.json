{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 26,
        "patch": 0
    },
    "include": [
        "./static-build/CMakePresets.json"
    ],
    "configurePresets": [
        {
            "name": "dynamic_base_configure",
            "displayName": "Dyncamic Base Configure",
            "binaryDir": "${sourceDir}/build",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "dynamic_base_asan_configure",
            "displayName": "Dynamic Base ASAN Configure",
            "inherits": "dynamic_base_configure",
            "hidden": true,
            "cacheVariables": {
                "ENABLE_WERROR": "ON",
                "ENABLE_ASAN": "ON",
                "ENABLE_UB_SANITIZER": "ON",
                "FIBER_STACK_SIZE": "1280Kb",
                "TEST_BUILD": "ON"
            }
        },
        {
            "name": "gcc_dynamic_base_configure",
            "displayName": "GCC Dyncamic Base Configure",
            "inherits": "dynamic_base_configure",
            "hidden": true,
            "environment": {
                "CC": "gcc",
                "CXX": "g++"
            }
        },
        {
            "name": "gcc_dynamic_base_asan_configure",
            "displayName": "GCC Dynamic Base ASAN Configure",
            "inherits": "dynamic_base_asan_configure",
            "hidden": true,
            "environment": {
                "CC": "gcc",
                "CXX": "g++"
            }
        },
        {
            "name": "clang_dynamic_base_configure",
            "displayName": "Clang Dyncamic Base Configure",
            "inherits": "dynamic_base_configure",
            "hidden": true,
            "environment": {
                "CC": "clang",
                "CXX": "clang++"
            }
        },
        {
            "name": "clang_dynamic_base_asan_configure",
            "displayName": "Clang Dyncamic Base ASAN Configure",
            "hidden": true,
            "inherits": "dynamic_base_asan_configure",
            "environment": {
                "CC": "clang",
                "CXX": "clang++"
            }
        },
        {
            "name": "gcc_dynamic_debug_configure",
            "displayName": "GCC Dynamic Debug Configure",
            "inherits": "gcc_dynamic_base_configure"
        },
        {
            "name": "gcc_static_debug_configure",
            "displayName": "GCC Static Debug Configure",
            "inherits": "gcc_static_base_configure"
        },
        {
            "name": "gcc_dynamic_release_configure",
            "displayName": "GCC Dynamic Release Configure",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            },
            "inherits": "gcc_dynamic_base_configure"
        },
        {
            "name": "gcc_static_release_configure",
            "displayName": "GCC Static Release Configure",
            "cacheVariables": {
                "CMAKE_TARANTOOL_ARGS": "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            },
            "inherits": "gcc_static_base_configure"
        },
        {
            "name": "gcc_dynamic_debug_asan_configure",
            "displayName": "GCC Dynamic Debug ASAN Configure",
            "inherits": "gcc_dynamic_base_asan_configure"
        },
        {
            "name": "gcc_static_debug_asan_configure",
            "displayName": "GCC Static Debug ASAN Configure",
            "inherits": "gcc_static_base_asan_configure"
        },
        {
            "name": "gcc_dynamic_release_asan_configure",
            "displayName": "GCC Dynamic Release ASAN Configure",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            },
            "inherits": "gcc_dynamic_base_asan_configure"
        },
        {
            "name": "gcc_static_release_asan_configure",
            "displayName": "GCC Static Release ASAN Configure",
            "cacheVariables": {
                "CMAKE_TARANTOOL_ARGS": "-DCMAKE_BUILD_TYPE=RelWithDebInfo;-DENABLE_WERROR=ON;-DENABLE_ASAN=ON;-DENABLE_UB_SANITIZER=ON;-DFIBER_STACK_SIZE=1280Kb;-DTEST_BUILD=ON"
            },
            "inherits": "gcc_static_base_asan_configure"
        },
        {
            "name": "clang_dynamic_debug_configure",
            "displayName": "Clang Dynamic Debug Configure",
            "inherits": "clang_dynamic_base_configure"
        },
        {
            "name": "clang_static_debug_configure",
            "displayName": "Clang Static Debug Configure",
            "inherits": "clang_static_base_configure"
        },
        {
            "name": "clang_dynamic_release_configure",
            "displayName": "Clang Dynamic Release Configure",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            },
            "inherits": "clang_dynamic_base_configure"
        },
        {
            "name": "clang_static_release_configure",
            "displayName": "Clang Static Release Configure",
            "cacheVariables": {
                "CMAKE_TARANTOOL_ARGS": "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            },
            "inherits": "clang_static_base_configure"
        },
        {
            "name": "clang_dynamic_debug_asan_configure",
            "displayName": "Clang Dynamic Debug ASAN Configure",
            "inherits": "clang_dynamic_base_asan_configure"
        },
        {
            "name": "clang_static_debug_asan_configure",
            "displayName": "Clang Static Debug ASAN Configure",
            "inherits": "clang_static_base_asan_configure"
        },
        {
            "name": "clang_dynamic_release_asan_configure",
            "displayName": "Clang Dynamic Release ASAN Configure",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            },
            "inherits": "clang_dynamic_base_asan_configure"
        },
        {
            "name": "clang_static_release_asan_configure",
            "displayName": "Clang Static Release ASAN Configure",
            "cacheVariables": {
                "CMAKE_TARANTOOL_ARGS": "-DCMAKE_BUILD_TYPE=RelWithDebInfo;-DENABLE_WERROR=ON;-DENABLE_ASAN=ON;-DENABLE_UB_SANITIZER=ON;-DFIBER_STACK_SIZE=1280Kb;-DTEST_BUILD=ON"
            },
            "inherits": "clang_static_base_asan_configure"
        }
    ],
